# ============================================================
# RunnerAI - template variabili d'ambiente
# Copia in .env e compila i valori.
# ============================================================

# --- Database (Postgres / Neon) ---
# Sviluppo e produzione usano Postgres (Neon). Copia la connection string
# "pooled" da Neon (console -> Connection Details). Deve includere sslmode=require.
# Es: postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/runnerai?sslmode=require
DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# --- App ---
APP_URL="http://localhost:3000"

# --- Auth.js / NextAuth v5 ---
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# --- Google social login (OAuth) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- LLM providers ---
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
DEEPSEEK_API_KEY=""

ANTHROPIC_MODEL="claude-opus-4-8"
ANTHROPIC_VISION_MODEL="claude-opus-4-8"
OPENAI_MODEL="gpt-4o"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
DEEPSEEK_MODEL="deepseek-chat"

PLAN_PROPOSER_A="claude"
PLAN_PROPOSER_B="openai"
PLAN_SUPERVISOR="deepseek"

# --- Email (Resend) ---
RESEND_API_KEY=""
EMAIL_FROM="RunnerAI <onboarding@resend.dev>"

# --- Rate limit distribuito (Upstash Redis REST, opzionale) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Monitoring errori (webhook opzionale) ---
ERROR_WEBHOOK_URL=""

# --- Web search ---
TAVILY_API_KEY=""
BRAVE_API_KEY=""

# --- Stripe ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""
STRIPE_PRICE_ID_PRO=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

TRIAL_DAYS="14"

# --- Sicurezza: cifratura token integrazioni (AES-256-GCM), 32 byte base64 ---
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=""

# --- Strava (OAuth2) ---
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""

# --- Garmin (Connect Developer / Health API, OAuth2 PKCE, richiede approvazione) ---
GARMIN_CLIENT_ID=""
GARMIN_CLIENT_SECRET=""

# --- Giorni di prova gratuita prima del pagamento ---
TRIAL_DAYS="14"

# --- Admin (email autorizzate, separate da virgola): monitoraggio token,
#     trigger manuale dei cron, override tier ---
ADMIN_EMAILS=""

# --- Servizi esterni (MCP server, agent worker) ---
# ATTENZIONE: in produzione questi placeholder NON sono accettati (il boot fallisce,
# vedi src/lib/env.ts) perché sono pubblicamente noti. Genera valori casuali:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Token per le chiamate servizio->servizio verso /api/service/*
SERVICE_TOKEN="dev-service-token-change-me"
# Secret per i trigger schedulati /api/cron/* (header: Authorization: Bearer ...)
CRON_SECRET="dev-cron-secret-change-me"

# --- Garmin Bridge (beta F&F): server isolato Docker che esegue garmin-givemydata ---
# URL del bridge (vedi services/garmin-bridge). Usa lo stesso SERVICE_TOKEN.
GARMIN_BRIDGE_URL=""

# --- Server MCP personale (Modulo 5) ---
# Il server MCP (services/mcp-server) NON usa il .env del web: ha il suo ambiente.
# I suoi strumenti "my_*" leggono i dati dell'utente via /api/mcp/* autenticandosi
# con un TOKEN PERSONALE (RUNNERAI_TOKEN) creato in RunnerAI → Integrazioni.
# Vedi services/mcp-server/README.md. Nessuna variabile da impostare qui.

# --- Storage oggetti S3-compatibile (Cloudflare R2 / AWS S3 / Backblaze B2) ---
# OBBLIGATORIO in produzione serverless: senza, le immagini generate (esercizi,
# base scientifica) e gli screenshot NON persistono (public/ è read-only). In
# sviluppo, se vuoto, si usa il filesystem locale (public/, ./uploads).
# R2: endpoint = https://<ACCOUNT_ID>.r2.cloudflarestorage.com, region "auto".
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION="auto"
# URL pubblico di lettura del bucket (dominio custom o r2.dev). Se vuoto si usa
# l'endpoint firmato (potrebbe non essere pubblicamente leggibile).
S3_PUBLIC_BASE_URL=""
